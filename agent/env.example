# Onyx Agent Runtime — copy to .env and fill in your values
# cp .env.example .env

VARA_NODE_URL=wss://rpc.vara.network
ONYX_PROGRAM_ID=0x9c2cfce724dcea96453eb7ef9c40ef67b572744374e6bc4195e030619ab02c33
VAN_PROGRAM_ID=0x19f27f4c906a5ac230be82d907850d44c7a7fff1b4c6903f62e78e09e0b353f3

# Paste your entire wallet JSON on ONE line (the .json file exported with --no-encrypt)
WALLET_JSON={"encoded":"...","encoding":{"content":["pkcs8","sr25519"],"type":["none"],"version":"3"},"address":"5...","meta":{}}

# Optional tuning
POLL_INTERVAL_SECONDS=6
REGISTRY_SYNC_INTERVAL_SECONDS=60
FETCH_LIMIT=20
LOG_LEVEL=INFO
LOG_FILE=onyx_agent.log
